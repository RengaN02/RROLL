{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "f582a54649d54ceeb570be5408462af0",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "GetFullDitherLight (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1029.5999755859375,
            "y": 2663.999755859375,
            "width": 259.2000732421875,
            "height": 301.60009765625
        }
    },
    "m_Slots": [
        {
            "m_Id": "c268bbdbeef34d17bdf777dc9c95ca65"
        },
        {
            "m_Id": "f5dc1f1f641e476d8ac8ccee5326fc49"
        },
        {
            "m_Id": "950ef5694dbb4a208bed8288737fae02"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "GetFullDitherLight",
    "m_FunctionSource": "4930a6d8af8af804fbd4d36c682dba92",
    "m_FunctionBody": "OutIntensity = 0;\r\n #ifndef SHADERGRAPH_PREVIEW\r\n    // 1. Ana Işık\r\n    Light mainLight = GetMainLight();\r\n    float mainDot = saturate(dot(WorldNormal, mainLight.direction));\r\n    OutIntensity += mainDot * mainLight.shadowAttenuation; // Mesafe azalımı ana ışıkta genelde 1'dir\r\n\r\n    // 2. Ek Işıklar (Point/Spot)\r\n    int pixelLightCount = GetAdditionalLightsCount();\r\n    for (int i = 0; i < pixelLightCount; ++i)\r\n    {\r\n        Light light = GetAdditionalLight(i, WorldPos);\r\n        float addDot = saturate(dot(WorldNormal, light.direction));\r\n        \r\n        // Şiddeti hesapla\r\n        float intensity = addDot * light.distanceAttenuation * light.shadowAttenuation;\r\n        \r\n        // --- HASSASİYET AYARI ---\r\n        // Işık çok zayıf olsa bile (uzaktayken) dither'ı etkilemesi için \r\n        // buradaki değeri bir miktar yukarı çekebiliriz.\r\n        intensity = pow(intensity, 0.5); // Işık zayıfken daha belirgin yapar (Karakök alma)\r\n        \r\n        OutIntensity += intensity;\r\n    }\r\n #else\r\n    OutIntensity = saturate(dot(WorldNormal, float3(0.5, 0.5, -0.5)));\r\n #endif\n"
}

